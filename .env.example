# Frontend API base path used by the browser.
# Keep this as /api in development so Vite can proxy requests.
VITE_API_BASE_URL=/api

# Backend repository link displayed in the header.
VITE_BACKEND_REPO_URL=https://github.com/maotovisk/mapping-feed

# Vite dev server proxy target.
# Change this if your backend is running in another host/port.
VITE_PROXY_TARGET=http://localhost:5000

# Local dev server port.
VITE_DEV_PORT=5173

# Production container port (used by docker-compose).
PORT=3000

# Bun runtime API proxy target for /api/* in production container.
# Set this to your Cloudflare-backed external API origin.
# If you set http://localhost:5000 while running in Docker,
# the runtime will automatically translate it to host.docker.internal:5000.
API_PROXY_TARGET=https://api.your-domain.com
